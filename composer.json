{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "^3.1",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^2.7",
        "jenssegers/agent": "^2.6",
        "ladumor/laravel-pwa": "^0.0.4",
        "laravel/framework": "^13.8",
        "laravel/sanctum": "^4.0",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^3.6",
        "maatwebsite/excel": "^3.1",
        "openai-php/laravel": "^0.19.1",
        "predis/predis": "^3.0",
        "pusher/pusher-php-server": "^7.2",
        "opcodesio/log-viewer": "^3.24",
        "silviolleite/laravelpwa": "^2.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-backup": "^10.2.1",
        "spatie/laravel-medialibrary": "^11.22.1",
        "wildbit/postmark-php": "^6.0",
        "yajra/laravel-datatables": "^13.0",
        "yajra/laravel-datatables-oracle": "^13.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.4",
        "phpunit/phpunit": "^12.5.12",
        "reliese/laravel": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "app/Console/Commands/bk-GenerateCard.php",
            "app/Providers/bk-AppServiceProvider.php"
        ],
        "files": [
            "app/Helpers/date.php",
            "app/Helpers/lang.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
